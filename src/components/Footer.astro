---
const year = new Date().getFullYear();
---

<footer class="bg-bg-dark text-white/60 py-10">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="text-center sm:text-left">
        <span class="text-xl font-extrabold text-white font-heading tracking-tight">SALCLOR</span>
        <p class="text-sm mt-1">Los inventores de la cloración salina · Desde 1991</p>
      </div>
      <div class="text-sm text-center sm:text-right">
        <p>&copy; {year} Salclor SL. Todos los derechos reservados.</p>
        <p class="mt-1">Madrid, España</p>
      </div>
    </div>
  </div>
</footer>
