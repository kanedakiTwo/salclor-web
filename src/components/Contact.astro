---
---

<section id="contacto" class="py-20 sm:py-28 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-primary mb-4">
        ¿Hablamos de tu piscina?
      </h2>
      <p class="text-lg sm:text-xl text-text-light">
        Pide tu presupuesto sin compromiso. Respondemos de lunes a domingo de 9h a 21h.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-10 items-start">
      <!-- Contact info + WhatsApp -->
      <div class="text-center md:text-left space-y-6">
        <a
          href="https://wa.me/NUMERO?text=Hola%2C%20me%20gustar%C3%ADa%20pedir%20informaci%C3%B3n%20sobre%20mi%20piscina"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 bg-whatsapp hover:bg-whatsapp-dark text-white text-lg font-bold px-8 py-4 rounded-full shadow-lg hover:shadow-xl transition-all duration-300 hover:scale-105 w-full justify-center md:w-auto"
        >
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          Escríbenos por WhatsApp
        </a>

        <div class="space-y-4">
          <a href="tel:+34NUMERO" class="flex items-center gap-3 text-text hover:text-accent transition-colors justify-center md:justify-start">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            <span class="text-lg font-medium">+34 XXX XXX XXX</span>
          </a>
          <div class="flex items-center gap-3 text-text-light justify-center md:justify-start">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span>Lunes a domingo · 9h a 21h</span>
          </div>
          <div class="flex items-center gap-3 text-text-light justify-center md:justify-start">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span>Servicio en Madrid</span>
          </div>
        </div>
      </div>

      <!-- Contact form -->
      <form class="bg-bg-light rounded-2xl p-6 sm:p-8 space-y-5" id="contact-form">
        <div>
          <label for="name" class="block text-sm font-medium text-text mb-1.5">Nombre</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-colors text-text"
            placeholder="Tu nombre"
          />
        </div>
        <div>
          <label for="phone" class="block text-sm font-medium text-text mb-1.5">Teléfono</label>
          <input
            type="tel"
            id="phone"
            name="phone"
            required
            class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-colors text-text"
            placeholder="Tu teléfono"
          />
        </div>
        <div>
          <label for="message" class="block text-sm font-medium text-text mb-1.5">Mensaje <span class="text-text-light">(opcional)</span></label>
          <textarea
            id="message"
            name="message"
            rows="3"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-accent focus:border-accent outline-none transition-colors text-text resize-none"
            placeholder="Cuéntanos brevemente qué necesitas"
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full bg-accent hover:bg-primary text-white font-bold py-3.5 rounded-lg transition-colors duration-200"
        >
          Enviar
        </button>
        <div id="form-success" class="hidden text-center text-whatsapp font-medium py-2">
          Gracias, te llamamos en menos de 24h.
        </div>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    // TODO: Connect to actual form backend (Netlify Forms, Formspree, etc.)
    form.reset();
    success?.classList.remove('hidden');
    setTimeout(() => success?.classList.add('hidden'), 5000);
  });
</script>
