---
import t from '../i18n/es';
---

<section id="historia" class="py-20 sm:py-28 bg-primary text-white">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold">
        {t.history.title}
      </h2>
    </div>

    <div class="max-w-4xl mx-auto flex flex-col md:flex-row items-center gap-10 mb-14">
      <img
        src="/images/patente-salclor-1991.jpeg"
        alt={t.history.patentAlt}
        class="w-56 md:w-64 rounded-lg shadow-lg border-2 border-white/20 shrink-0"
        width="800"
        height="1067"
        loading="lazy"
      />
      <div class="text-center md:text-left">
        <p class="text-lg text-white/80 leading-relaxed mb-4">
          {t.history.paragraphs[0]}
        </p>
        <p class="text-lg text-white/80 leading-relaxed mb-4">
          {t.history.paragraphs[1]}
        </p>
        <p class="text-lg text-white font-semibold leading-relaxed">
          {t.history.paragraphs[2]}
        </p>
      </div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {t.history.stats.map(s => (
        <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-4 sm:p-6 text-center">
          <div class="text-2xl sm:text-3xl lg:text-4xl font-extrabold text-white mb-1">{s.value}</div>
          <div class="text-xs sm:text-sm text-white/60 font-medium uppercase tracking-wider">{s.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
