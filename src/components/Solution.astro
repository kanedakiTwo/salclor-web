---
import t from '../i18n/es';
---

<section id="solucion" class="py-20 sm:py-28 bg-bg-light">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-primary mb-6">
        {t.solution.title}
      </h2>
      <p class="text-lg sm:text-xl text-text-light max-w-3xl mx-auto leading-relaxed">
        {t.solution.description}
      </p>
      <p class="mt-4 text-lg text-text-light max-w-3xl mx-auto leading-relaxed">
        {t.solution.description2}
      </p>
      <p class="mt-4 text-lg sm:text-xl font-semibold text-primary">
        {t.solution.punchline}
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6 sm:gap-8">
      <div class="bg-white rounded-2xl p-6 sm:p-8 border-2 border-red-200">
        <h3 class="text-xl font-bold text-red-600 mb-5 flex items-center gap-2">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          {t.solution.traditionalTitle}
        </h3>
        <ul class="space-y-3">
          {t.solution.traditional.map(item => (
            <li class="flex items-start gap-3 text-text-light">
              <svg class="w-5 h-5 text-red-400 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
              {item}
            </li>
          ))}
        </ul>
      </div>

      <div class="bg-white rounded-2xl p-6 sm:p-8 border-2 border-whatsapp/40 shadow-md">
        <h3 class="text-xl font-bold text-primary mb-5 flex items-center gap-2">
          <svg class="w-6 h-6 text-whatsapp" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
          {t.solution.salineTitle}
        </h3>
        <ul class="space-y-3">
          {t.solution.saline.map(item => (
            <li class="flex items-start gap-3 text-text">
              <svg class="w-5 h-5 text-whatsapp shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              {item}
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
