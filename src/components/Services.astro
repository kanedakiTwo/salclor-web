---
import t from '../i18n/es';
---

<section id="servicios" class="py-20 sm:py-28 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-6">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-primary mb-6">
        {t.services.title}
      </h2>
      <p class="text-lg sm:text-xl text-text-light max-w-3xl mx-auto">
        {t.services.subtitle}
      </p>
    </div>

    <!-- Servicio estrella: visible sin acordeón -->
    <div class="mt-12 mb-8 rounded-2xl border-2 border-accent bg-accent/5 p-6 sm:p-8 flex flex-col sm:flex-row items-center gap-6">
      <img
        src="/images/clorador-50-gramos-1.jpg"
        alt={t.services.starImgAlt}
        class="w-40 sm:w-48 object-contain shrink-0"
        width="500"
        height="500"
        loading="lazy"
      />
      <div>
        <p class="text-xs font-bold text-accent uppercase tracking-wider mb-2">{t.services.starLabel}</p>
        <h3 class="text-xl sm:text-2xl font-bold text-primary mb-2">
          {t.services.starTitle}
        </h3>
        <p class="text-text-light">
          {t.services.starDesc}
        </p>
      </div>
    </div>

    <!-- Resto de servicios en acordeón -->
    <div class="space-y-3">
      {t.services.categories.map((s, i) => (
        <div class="rounded-2xl border border-gray-200 bg-white overflow-hidden">
          <button
            class="accordion-trigger w-full flex items-center justify-between px-6 py-5 text-left hover:bg-bg-light/50 transition-colors"
            aria-expanded="false"
            aria-controls={`accordion-${i}`}
            data-index={i}
          >
            <span class="text-lg font-bold text-primary">
              {s.category}
            </span>
            <svg class="accordion-icon w-5 h-5 text-text-light transition-transform duration-300 shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div id={`accordion-${i}`} class="accordion-content px-6 overflow-hidden transition-all duration-300 max-h-0" role="region">
            <ul class="space-y-2">
              {s.items.map(item => (
                <li class="flex items-start gap-3 text-text">
                  <svg class="w-5 h-5 text-whatsapp shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.accordion-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const content = btn.nextElementSibling as HTMLElement;
      const icon = btn.querySelector('.accordion-icon') as HTMLElement;
      const isOpen = btn.getAttribute('aria-expanded') === 'true';

      if (isOpen) {
        content.style.maxHeight = '0';
        content.classList.remove('pb-5');
        btn.setAttribute('aria-expanded', 'false');
        icon.style.transform = 'rotate(0deg)';
      } else {
        content.style.maxHeight = content.scrollHeight + 20 + 'px';
        content.classList.add('pb-5');
        btn.setAttribute('aria-expanded', 'true');
        icon.style.transform = 'rotate(180deg)';
      }
    });

    if (btn.getAttribute('aria-expanded') === 'true') {
      const icon = btn.querySelector('.accordion-icon') as HTMLElement;
      if (icon) icon.style.transform = 'rotate(180deg)';
    }
  });
</script>
